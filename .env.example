# Base URL for the NURA backend API (include /api/v1 suffix).
# The Vite dev server uses this as the proxy target for /api/v1 requests,
# and the client reads it via import.meta.env.VITE_BASE_API_URL.
#
# Staging (mock Stripe + predefined OTP):
VITE_BASE_API_URL=https://nura-api-staging.replit.app/api/v1
#
# Production (real Stripe):
# VITE_BASE_API_URL=https://nura-api.replit.app/api/v1
